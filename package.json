{
  "name": "markdown-lint",
  "displayName": "Markdown Lint Preview",
  "description": "Enhanced Markdown preview with multiple themes, table of contents, math formulas, code highlighting, and export capabilities.",
  "version": "0.2.0",
  "publisher": "hyshine",
  "license": "MIT",
  "author": "jessy",
  "repository": {
    "type": "git",
    "url": "https://github.com/hy-shine/vscode-markdown-lint.git"
  },
  "bugs": {
    "url": "https://github.com/hy-shine/vscode-markdown-lint/issues"
  },
  "homepage": "https://github.com/hy-shine/vscode-markdown-lint#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "keywords": [
  "markdown",
  "preview",
  "toc",
  "mermaid",
  "formatter"
],
  "icon": "images/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "contributes": {
    "commands": [
      {
        "command": "markdown-lint.openPreview",
        "title": "Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "markdown-lint.formatDocument",
        "title": "Markdown Lint: Format Document"
      },
      {
        "command": "markdown-lint.refreshToc",
        "title": "Markdown Lint: Refresh TOC"
      },
      {
        "command": "markdown-lint.exportHtml",
        "title": "Markdown Lint: Export HTML"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdown-lint.openPreview",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "markdown-lint",
      "properties": {
        "markdown-lint.themeMode": {
          "type": "string",
          "enum": ["auto", "light", "dark"],
          "default": "auto",
          "description": "Theme mode for the Markdown Lint preview."
        },
        "markdown-lint.previewStyle": {
          "type": "string",
          "enum": ["default", "github", "notion", "tokyo-night", "obsidian", "paper", "typora"],
          "enumDescriptions": [
            "Default clean style",
            "GitHub-flavored markdown style",
            "Notion-like minimal style",
            "Tokyo Night dark theme style",
            "Obsidian-inspired style",
            "Paper-like document style",
            "Typora-inspired style (Whitey light / Night dark)"
          ],
          "default": "default",
          "description": "Preview style preset for the Markdown Lint preview. Options: default, github, notion, tokyo-night, obsidian, paper."
        },
        "markdown-lint.showToc": {
          "type": "boolean",
          "default": true,
          "description": "Show the table of contents sidebar in the preview."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --platform=node --outfile=dist/extension.js --external:vscode --format=cjs --sourcemap",
    "watch": "npm run compile -- --watch"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.22",
    "marked": "^15.0.12"
  }
}
