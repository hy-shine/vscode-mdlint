{
  "name": "mdlint",
  "displayName": "mdlint",
  "description": "A Markdown linter for VS Code with enhanced preview, navigation, theming, and formatting foundations.",
  "version": "0.0.1-beta",
  "publisher": "jessy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Markdown"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mdlint.openPreview",
        "title": "mdlint: Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "mdlint.formatDocument",
        "title": "mdlint: Format Document"
      },
      {
        "command": "mdlint.refreshToc",
        "title": "mdlint: Refresh TOC"
      },
      {
        "command": "mdlint.exportHtml",
        "title": "mdlint: Export HTML"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mdlint.openPreview",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "mdlint",
      "properties": {
        "mdlint.themeMode": {
          "type": "string",
          "enum": ["auto", "light", "dark"],
          "default": "auto",
          "description": "Theme mode for the Markdown Workbench preview."
        },
        "mdlint.previewStyle": {
          "type": "string",
          "enum": ["default", "github", "notion", "tokyo-night", "obsidian"],
          "default": "default",
          "description": "Preview style preset for the Markdown Workbench preview. Options: default, github, notion, tokyo-night, obsidian."
        },
        "mdlint.showToc": {
          "type": "boolean",
          "default": true,
          "description": "Show the table of contents sidebar in the preview."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --platform=node --outfile=dist/extension.js --external:vscode --format=cjs --sourcemap",
    "watch": "npm run compile -- --watch"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.22",
    "marked": "^15.0.12"
  }
}
